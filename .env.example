# Copy this file to .env and fill in your real values.
# Never commit the actual .env file.

# Bearer token extracted from DevTools (Network tab -> request headers -> Authorization)
# Grab it from any XHR request to *.scorito.com while logged into the Gamecenter.
SCORITO_BEARER_TOKEN=paste_your_token_here

# The "game" id for the tournament (visible in the ranking page URL:
# scorito.com/footballtournament/ranking/{marketId}/{poolId})
SCORITO_MARKET_ID=301

# Your pool's id (the second number in that same URL)
SCORITO_POOL_ID=1043539

# The football event id used by football.scorito.com endpoints (e.g. 750 for WK 2026)
SCORITO_EVENT_ID=750

# Offset used to derive prediction "round ids" from the match schema's
# EventRoundOrder (roundId = offset + order). Reverse-engineered per market;
# only change this if predictions come back empty for rounds that have matches.
SCORITO_ROUND_ID_OFFSET=7161

# Id used by the topscorerprediction endpoint for this market (reverse-engineered;
# unrelated to the match round ids above).
SCORITO_TOPSCORER_PREDICTION_ID=460
